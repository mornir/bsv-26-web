---
import { locales } from '@/i18n/utils'
import { getLocaleUrl, getLocale } from 'astro-i18n-aut'
import NavDropDown from './NavDropDown.astro'
import { useTranslations } from '@/i18n/utils'
const locale = getLocale(Astro.url) as LangKeys
const t = useTranslations(locale)
---

<NavDropDown
  name={t('lang')}
  links={Object.entries(locales).map(([lang]) => ({
    name: t('lang'),
    path: lang,
  }))}
/>
