---
import type { GetArticleQueryResult } from '../../sanity.types'
interface Props {
  articles: GetArticleQueryResult[]
}

const { articles } = Astro.props
---

<ul class="text-xs ms-4 space-y-2">
  {
    articles.map((art) => (
      <li>
        <a href={`#art-${art.number}`}>
          Art.&nbsp;{art.number}&nbsp;{art.name.de}
        </a>
      </li>
    ))
  }
</ul>
