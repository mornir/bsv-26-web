---
import { ChevronDown, ChevronRight } from '@lucide/astro'
---

<div x-data="{ expanded: false }" role="region">
  <h3>
    <button
      type="button"
      x-on:click="expanded = !expanded"
      :aria-expanded="expanded"
      class="flex w-full items-center gap-2 rounded-lg bg-blue-50 px-4 py-3 text-left font-medium text-blue-900 transition-colors hover:bg-blue-100"
    >
      <ChevronDown x-show="expanded" class="h-5 w-5" />

      <ChevronRight x-show="!expanded" class="h-5 w-5" />

      <span>Question #1</span>
    </button>
  </h3>

  <div
    x-show="expanded"
    x-collapse
    class="rounded-r-lg border-l-4 border-blue-500 bg-blue-50 p-5"
  >
    <p class="leading-relaxed text-blue-900">
      Lorem ipsum dolor sit amet consectetur adipisicing elit. In magnam quod
      natus deleniti architecto eaque consequuntur ex, illo neque iste
      repellendus modi, quasi ipsa commodi saepe? Provident ipsa nulla earum.
    </p>
  </div>
</div>
