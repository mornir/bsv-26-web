---
import { getNav } from '../utils/sanity'

const nav = await getNav()
---

<aside
  id="default-sidebar"
  class="fixed top-0 left-0 z-40 w-64 h-screen
transition-transform -translate-x-full sm:translate-x-0"
  aria-label="Sidebar"
>
  <nav class="h-full px-3 py-4 overflow-y-auto bg-gray-50 dark:bg-gray-800">
    <ul class="space-y-2 font-medium">
      {
        nav.map((item: any) => (
          <li class="flex items-center p-2 text-gray-900 dark:text-white">
            <details>
              <summary class="text-sm">
                {item.number}
                {item.name.de}
              </summary>
              <ul class="text-xs ms-4">
                <li>Art. 1 Nachweis</li>
                <li>Art. 2 Nachweis</li>
                <li>Art. 3 Nachweis</li>
                <li>Art. 4 Nachweis</li>
              </ul>
            </details>
          </li>
        ))
      }
    </ul>
  </nav>
</aside>
