---
import type { BlockProps } from 'astro-portabletext/types'
import { Block as DefaultBlock } from 'astro-portabletext/components'

type Props = BlockProps

const props = Astro.props
---

<DefaultBlock
  {...props}
  class:list={'my-2 text-lg leading-relaxed text-slate-800'}
  ><slot /></DefaultBlock
>
