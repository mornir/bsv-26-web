---
import { Maximize2 } from '@lucide/astro'
const { node } = Astro.props
---

<div class="mt-2 mb-6">
  <div class="flex justify-end mb-4">
    <button
      class="flex items-center gap-2 px-3 py-2 text-xs font-medium text-slate-700 bg-slate-100 hover:bg-slate-200 rounded-lg transition-colors border border-slate-300 whitespace-nowrap"
    >
      <Maximize2 class="h-4 w-4" />
      <span>Tabelle vergrössern</span>
    </button>
  </div>
  <div class="max-w-full overflow-x-auto">
    <Fragment set:html={node.html} />
  </div>
</div>
