---
import { PortableText } from 'astro-portabletext'
import BasicInternalLink from './InternalLink.astro'

interface Props {
  blocks: any
}

const { blocks } = Astro.props

const components = {
  mark: {
    internalLink: BasicInternalLink,
  },
}
---

<PortableText value={blocks} components={components} />
