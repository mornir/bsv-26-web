---
const {
  node: { listItem, level },
  index,
} = Astro.props

// Tip: Classes added to fragment/slot are passed to Astro.props
// https://github.com/theisel/astro-portabletext/blob/main/examples/portabletext-slots.astro
---

{
  listItem === 'number' ? (
    <ol
      class:list={[
        'my-4 list-inside space-y-2 marker:text-slate-500',
        {
          'list-[superscript-numbers]': level === 1 && index !== 1,
          'list-[lower-alpha]': level === 2 || (level === 1 && index === 1),
          'list-decimal': level === 3,
        },
      ]}
    >
      <slot />
    </ol>
  ) : (
    <ul class="my-4 list-inside list-disc space-y-2 marker:text-slate-500">
      <slot />
    </ul>
  )
}

<style>
  @counter-style superscript-numbers {
    system: numeric;
    symbols: '⁰' '¹' '²' '³' '⁴' '⁵' '⁶' '⁷' '⁸' '⁹';
    suffix: ' '; /* Space after the number. */
  }
</style>
