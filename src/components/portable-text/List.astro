---
const {
  node: { listItem, level },
  index,
} = Astro.props

// Tip: Classes added to fragment/slot are passed to Astro.props
// https://github.com/theisel/astro-portabletext/blob/main/examples/portabletext-slots.astro
---

{
  listItem === 'number' ? (
    <ol
      class:list={[
        'marker:text-slate-500 list-inside grid grid-rows-subgrid row-span-20',
        {
          'my-4 list-[superscript-numbers] space-y-4':
            level === 1 && index !== 1,
          'my-2 list-[lower-alpha] space-y-2 pl-2':
            level === 2 || (level === 1 && index === 1),
          'my-2 list-decimal space-y-2 pl-2': level === 3,
        },
      ]}
    >
      <slot />
    </ol>
  ) : (
    <ul class="my-2 list-inside list-disc space-y-2 marker:text-slate-500">
      <slot />
    </ul>
  )
}

<style>
  @counter-style superscript-numbers {
    system: numeric;
    symbols: '⁰' '¹' '²' '³' '⁴' '⁵' '⁶' '⁷' '⁸' '⁹';
    suffix: ' '; /* Space after the number. */
  }
</style>
