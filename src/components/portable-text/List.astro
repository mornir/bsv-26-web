---
const {
  node: { listItem, level },
  index,
} = Astro.props

// Tip: Custom component properties added to Fragment are passed down to Astro.props
// https://github.com/theisel/astro-portabletext/blob/main/examples/portabletext-slots.astro

// If 'grid grid-rows-subgrid row-span-20' causes perfomance issue, remove them for monolingual view, using framgent/slot.
---

{
  listItem === 'number' ? (
    <ol
      class:list={[
        'marker:text-slate-500 list-inside grid grid-rows-subgrid row-span-20 text-lg leading-relaxed text-slate-800',
        {
          'my-4 list-[superscript-numbers] space-y-4':
            level === 1 && index !== 1,
          'my-2 list-[lower-alpha] space-y-2 pl-2':
            level === 2 || (level === 1 && index === 1),
          'my-2 list-decimal space-y-2 pl-2': level === 3,
        },
      ]}
    >
      <slot />
    </ol>
  ) : (
    <ul class="my-2 list-inside list-disc space-y-2 marker:text-slate-500 grid grid-rows-subgrid row-span-20 text-lg leading-relaxed text-slate-800">
      <slot />
    </ul>
  )
}

<style>
  @counter-style superscript-numbers {
    system: numeric;
    symbols: '⁰' '¹' '²' '³' '⁴' '⁵' '⁶' '⁷' '⁸' '⁹';
    suffix: ' '; /* Space after the number. */
  }
</style>
