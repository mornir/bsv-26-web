---
import RichText from '@/components/portable-text/RichText.astro'
import { ChevronRight } from '@lucide/astro'
import type { ArticleView } from '@/pages/art/[number].astro'

interface Props {
  article: ArticleView
}

const {
  title,
  chapter,
  section,
  number,
  law,
  exp = null,
  name,
} = Astro.props.article
---

<article
  class="mx-auto mt-18 mb-24 max-w-3xl bg-white p-6 rounded-lg border border-slate-300"
>
  <!-- Article Header -->
  <header>
    <!-- Breadcrumbs - Hierarchical information -->
    <nav class="mb-6" aria-label="Breadcrumb">
      <ol class="flex flex-wrap items-center gap-2 text-sm text-slate-600">
        {
          [title, chapter, section]
            .filter((heading) => Boolean(heading.number))
            .map((heading, i, arr) => (
              <li class="flex items-center gap-1">
                <span class="font-medium text-slate-900">
                  {heading.number}. Titel
                </span>
                <span class="text-slate-400">·</span>
                <span>{heading.name}</span>
                {i < arr.length - 1 && (
                  <ChevronRight class="h-4 w-4 text-slate-400" />
                )}
              </li>
            ))
        }
      </ol>
    </nav>
    <div class="mb-2 font-mono text-slate-600">
      Artikel <span>{number}</span>
    </div>
    <h1 class="font-serif text-3xl leading-tight">
      {name}
    </h1>
  </header>

  <!-- Vorschriftentext -->
  <RichText blocks={law} />

  <!-- Erläuterung -->
  {
    exp && (
      <div class="mt-8 w-fit rounded-r-md border-l-4 border-blue-500 bg-blue-50 p-6">
        <h2 class="mb-4 text-xl font-semibold text-blue-900">
          Erläuterung zum Art. {number}
        </h2>
        <div class="text-blue-900">
          <RichText blocks={exp} />
        </div>
      </div>
    )
  }
</article>
