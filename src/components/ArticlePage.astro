---
import RichText from '@/components/portable-text/RichText.astro'
import { ChevronRight } from '@lucide/astro'

import type { ArticleView } from '@/pages/art/[number].astro'

interface Props {
  article: ArticleView
}

const {
  title,
  chapter,
  section,
  number,
  law,
  exp = null,
  name,
} = Astro.props.article

// mx-auto prose scroll-mt-12 prose-stone prose-p:my-2 prose-ol:mt-0 prose-ol:mb-2 prose-ul:mt-0 prose-ul:mb-2 prose-thead:font-semibold
---

<article id={`art-${number}`} class="mx-auto mt-18 mb-24 max-w-3xl">
  <!-- Article Header -->
  <header>
    <!-- Breadcrumbs - Hierarchical information -->
    <nav class="mb-6" aria-label="Breadcrumb">
      <ol class="flex flex-wrap items-center gap-2 text-sm text-gray-600">
        <li class="flex items-center gap-2">
          <span class="font-medium text-gray-900">
            {title.number}. Titel
          </span>
          <span class="text-gray-400">·</span>
          <span>{title.name}</span>
        </li>
        <ChevronRight class="h-4 w-4 text-gray-400" />
        <li class="flex items-center gap-2">
          <span class="font-medium text-gray-900">
            {chapter.number}. Kapitel
          </span>
          <span class="text-gray-400">·</span>
          <span>{chapter.name}</span>
        </li>
        <ChevronRight class="h-4 w-4 text-gray-400" />
        <li class="flex items-center gap-2">
          <span class="font-medium text-gray-900">
            {section.number}. Abschnitt
          </span>
          <span class="text-gray-400">·</span>
          <span>{section.name}</span>
        </li>
      </ol>
    </nav>
    <div class="mb-2 font-mono text-slate-600">
      Artikel <span>{number}</span>
    </div>
    <h1 class="font-serif text-3xl leading-tight">
      {name}
    </h1>
  </header>

  <!-- Vorschriftentext -->
  <RichText blocks={law} />

  <!-- Erläuterung -->
  {
    exp && (
      <div class="mt-8 w-fit rounded-r-xl border-l-4 border-blue-500 bg-blue-50 p-6">
        <h2 class="mb-4 text-xl font-semibold text-blue-900">
          Erläuterung zum Art. {number}
        </h2>
        <div class="text-blue-900">
          <RichText blocks={exp} />
        </div>
      </div>
    )
  }
</article>
