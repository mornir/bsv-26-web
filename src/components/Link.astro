---
import { getLocaleUrl, getLocale } from 'astro-i18n-aut'
const locale = getLocale(Astro.url)

const pathname = Astro.url.pathname

const { text = 'TEXT', slug = '/' } = Astro.props

const path = `/${slug}`
---

<a
  href={getLocaleUrl(path, locale)}
  class={`hover:text-accent ${pathname === path && 'text-accent'}`}>{text}</a
>
