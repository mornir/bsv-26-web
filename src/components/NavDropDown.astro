---
import { ChevronDown } from '@lucide/astro'
type Links = {
  name: string
  path: string
}

interface Props {
  name: string
  links: Links[]
}

const { name, links } = Astro.props
const pathname = Astro.url.pathname
---

<div class="flex justify-center">
  <div
    x-data="{
          open: false,
          toggle() {
              if (this.open) {
                  return this.close()
              }

              this.$refs.button.focus()

              this.open = true
          },
          close(focusAfter) {
              if (! this.open) return

              this.open = false

              focusAfter && focusAfter.focus()
          }
      }"
    x-on:keydown.escape.prevent.stop="close($refs.button)"
    x-on:focusin.window="! $refs.panel.contains($event.target) && close()"
    x-id="['dropdown-button']"
    class="relative"
  >
    <!-- Button -->
    <button
      x-ref="button"
      x-on:click="toggle()"
      :aria-expanded="open"
      :aria-controls="$id('dropdown-button')"
      type="button"
      class="relative flex cursor-pointer items-center justify-center gap-2 px-4 py-2 whitespace-nowrap text-gray-800 hover:text-accent"
    >
      <span>{name}</span>

      <ChevronDown size="16" />
    </button>

    <!-- Panel -->
    <div
      x-ref="panel"
      x-show="open"
      x-transition.origin.top.left
      x-on:click.outside="close($refs.button)"
      :id="$id('dropdown-button')"
      x-cloak
      class="absolute left-0 z-20 mt-2 min-w-48 origin-top-left rounded-lg border border-gray-200 bg-white p-1.5 shadow-sm outline-none"
    >
      {
        links.map((link) => (
          <a
            href={link.path}
            class={`flex w-full items-center rounded-md px-2 py-2 text-left transition-colors hover:bg-gray-50 focus-visible:bg-gray-50 lg:py-1.5 ${pathname === link.path ? 'text-accent' : 'text-gray-800'}`}
          >
            {link.name}
          </a>
        ))
      }
    </div>
  </div>
</div>
