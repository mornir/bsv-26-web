---
import { ChevronDown } from '@lucide/astro'
import { getLocaleUrl, getLocale } from 'astro-i18n-aut'
const locale = getLocale(Astro.url)

type Links = {
  name: string
  path: string
}

// TODO: remove select prop if no longer needed in navbar
interface Props {
  name: string
  links: Links[]
  select?: Boolean
}

const { name, links, select = false } = Astro.props
const pathname = Astro.url.pathname
---

<div class="flex items-center">
  <div
    x-data="{
          open: false,
          toggle() {
              if (this.open) {
                  return this.close()
              }
              this.$refs.button.focus()
              this.open = true
          },
          close(focusAfter) {
              if (! this.open) return
              this.open = false
              focusAfter && focusAfter.focus()
          }
      }"
    x-on:keydown.escape.prevent.stop="close($refs.button)"
    x-on:focusin.window="! $refs.panel.contains($event.target) && close()"
    x-id="['dropdown-button']"
    class="relative"
  >
    <!-- Button -->
    <button
      x-ref="button"
      x-on:click="toggle()"
      :aria-expanded="open"
      :aria-controls="$id('dropdown-button')"
      type="button"
      class:list={[
        'relative inline-flex cursor-pointer items-center gap-2 rounded-md border-slate-300 font-medium text-slate-800 transition-colors duration-150 hover:text-slate-900',
        {
          'border bg-slate-50 px-3 py-1.5 hover:bg-slate-100': select,
          'hover:underline': !select,
        },
      ]}
    >
      <span class="hover:text-underline leading-tight text-slate-700"
        >{name}</span
      >

      <ChevronDown size="16" class="text-slate-500" />
    </button>

    <!-- Panel -->
    <div
      x-ref="panel"
      x-show="open"
      x-transition.origin.top.left
      x-on:click.outside="close($refs.button)"
      :id="$id('dropdown-button')"
      x-cloak
      class="absolute left-0 z-20 mt-2 min-w-25 origin-top-left rounded-md border border-slate-200 bg-white p-1.5 shadow-sm outline-none"
    >
      {
        links.map((link) => (
          <a
            href={
              link.path.startsWith('/')
                ? link.path
                : getLocaleUrl('/' + link.path, locale)
            }
            class={`flex w-full items-center rounded-md px-3 py-2 text-left text-sm transition-colors hover:bg-slate-50 focus-visible:bg-slate-50 ${pathname === link.path ? 'font-semibold text-primary' : 'text-slate-800'}`}
          >
            {link.name}
          </a>
        ))
      }
    </div>
  </div>
</div>
