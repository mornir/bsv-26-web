---
import { ChevronRight, BookOpen, Book, FileText, Layers } from '@lucide/astro'

const { title, chapter, section, number, name } = Astro.props
---

<header class="mb-6">
  {/* Hierarchical Pills */}
  <div class="mb-8 flex flex-wrap items-center gap-2">
    {/* Titel Pill */}
    <div
      class="inline-flex font-medium items-center gap-2 px-3 py-1.5 bg-purple-50 text-purple-600 rounded-full text-xs"
    >
      <Book class="w-3.5 h-3.5" />
      <span>1. Titel:</span>
      <span>Brandschutzmassnahemen</span>
    </div>

    {/* Kapitel Pill */}
    <div
      class="inline-flex items-center gap-2 px-3 py-1.5 bg-indigo-50 text-indigo-600 rounded-full text-xs"
    >
      <Layers class="w-3.5 h-3.5" />
      <span class="font-medium">2. Kapitel:</span>
      <span>Flucht- und Rettungswege</span>
    </div>

    {/* Abschnitt Pill */}
    <div
      class="inline-flex items-center gap-2 px-3 py-1.5 bg-sky-50 text-sky-600 rounded-full text-xs"
    >
      <FileText class="w-3.5 h-3.5" />
      <span class="font-medium">3. Abschnitt</span>
      <span>Brandabschnitte</span>
    </div>
  </div>

  <div class="mb-1 font-mono text-slate-600">Artikel 1</div>
  <h1 class="font-serif text-2xl leading-tight">Schutzziele</h1>
</header>
