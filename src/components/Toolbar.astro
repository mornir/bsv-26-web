---
interface Props {
  number?: number
}

const expOptions = [
  {text: 'anzeigen', value: 'show'},
  {text: 'umschalten', value: 'toggle'},
  {text: 'ausblenden', value: 'hide'},
]

const {number} = Astro.props
---

<div class="sticky top-0 p-4 flex justify-between bg-gray-100 items-center z-10">
  <div class="flex gap-x-4">
    {!number && <span>Erläuterungen:</span>}
    {
      !number ? (
        expOptions.map(({text, value}) => (
          <div>
            <input
              type="radio"
              value={value}
              x-model="exp"
              name={text}
              class="accent-accent"
              id={value}
            />
            <label for={value}>{text}</label>
          </div>
        ))
      ) : (
        <a
          href={`/gesamtwerk#art-${number}`}
          class="bg-primary hover:bg-accent duration-700 ease-out py-2 px-4 text-white"
        >
          Artikel im Gesamtwerk anzeigen
        </a>
      )
    }
  </div>
  <div class="flex gap-x-4 justify-end">
    <span>Sprachvergleich:</span>
    <div>
      <input
        type="checkbox"
        value="de"
        x-model="languages"
        name="german"
        class="accent-violet-800"
        id="de"
      />
      <label for="de">Deutsch</label>
    </div>
    <div>
      <input
        type="checkbox"
        value="fr"
        x-model="languages"
        name="french"
        class="accent-violet-800"
        id="fr"
      />
      <label for="fr">Französisch</label>
    </div>
    <div>
      <input
        type="checkbox"
        value="it"
        x-model="languages"
        name="italian"
        class="accent-violet-800"
        id="it"
      />
      <label for="it">Italienisch</label>
    </div>
  </div>
</div>
