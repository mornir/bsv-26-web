---
import type { BlockContent } from '@/types/sanity.types'
import RichText from '@/components/portable-text/RichText.astro'
import { Link2, Check } from '@lucide/astro'
import { locales, formatRef } from '@/i18n/utils'

interface Props {
  title: String
  number: Number
  law: BlockContent
  exp?: BlockContent
}

const { title, number, law, exp = [] } = Astro.props
---

<article
  class="mx-auto prose scroll-mt-12 prose-stone prose-p:my-2 prose-ol:mt-0 prose-ol:mb-2 prose-ul:mt-0 prose-ul:mb-2 prose-thead:font-semibold"
  id={`art-${number}`}
>
  <h1>Art. {number} {title}</h1>

  <RichText blocks={law} />
  <RichText blocks={exp} />
</article>
