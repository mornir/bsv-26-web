---
import Article from '@/components/Article.astro'
import Toolbar from '@/components/Toolbar.astro'
import Layout from '@/layouts/Layout.astro'
import { getArticles } from '@/sanity/queries'
import SideNav from '@/components/SideNav.astro'
import TestTable from '@/components/TestTable.astro'

const articles = await getArticles()
---

<Layout title="Gesamtwerk">
  <div class="c-grid-wrapper">
    <div class="c-sidenav">
      <SideNav />
    </div>
    <div x-data="$store.toolbar" class="c-main mb-24">
      <Toolbar />
      <section class="mx-auto max-w-7xl">
        {articles.map((article: any) => <Article article={article} />)}
      </section>
      <section
        class="mx-auto prose max-w-5xl prose-stone prose-p:my-2 prose-thead:font-semibold"
      >
        <TestTable />
      </section>
    </div>
  </div>
</Layout>

<style>
  .c-grid-wrapper {
    display: grid;
    grid-template-columns: 18rem 1fr;
    grid-template-areas: 'sidenav main';
  }

  .c-main {
    grid-area: 'main';
  }

  .c-sidenav {
    grid-area: 'sidenav';
  }
</style>
