---
import type { InferGetStaticParamsType } from 'astro'
import { PortableText } from 'astro-portabletext'
import Layout from '../../layouts/Layout.astro'
import { getArticle, getArticles } from '../../utils/sanity'

export async function getStaticPaths() {
  const articles = await getArticles()
  return articles.map((article) => ({
    params: { number: article.number.toString() },
  }))
}

type Params = InferGetStaticParamsType<typeof getStaticPaths>
const { number } = Astro.params as Params

// if (!number) return Astro.redirect('/404')

console.log(typeof number)

const article = await getArticle(parseInt(number))
console.log(article)
---

<Layout title="Article">
  <div>Good dog, {article.number}!</div>
</Layout>
