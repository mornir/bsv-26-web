---
import Article from '../components/Article.astro'
import Layout from '../layouts/Layout.astro'
import { getArticles } from '../utils/sanity'

const articles = await getArticles()
---

<Layout title="BSV 2026">
  <div x-data="{ languages: ['de'], exp: 'show'}">
    <div class="sticky top-0 p-4 flex justify-between bg-gray-100">
      <div class="flex gap-x-4">
        <span>Erläuterungen:</span>
        <div>
          <input type="radio" value="show" x-model="exp" name="show" />
          <label for="show">Anzeigen</label>
        </div>
        <div>
          <input type="radio" value="toggle" x-model="exp" name="toggle" />
          <label for="toggle">Toggle</label>
        </div>
        <div>
          <input type="radio" value="hide" x-model="exp" name="hide" />
          <label for="hide">Ausblenden</label>
        </div>
      </div>
      <div class="flex gap-x-4 justify-end">
        <div>
          <input type="checkbox" value="de" x-model="languages" name="german" />
          <label for="german">Deutsch</label>
        </div>
        <div>
          <input type="checkbox" value="fr" x-model="languages" name="french" />
          <label for="french">Französisch</label>
        </div>
        <div>
          <input
            type="checkbox"
            value="it"
            x-model="languages"
            name="italian"
          />
          <label for="italian">Italienisch</label>
        </div>
      </div>
    </div>
    <section class="mx-auto max-w-7xl">
      {articles.map((article) => <Article article={article} />)}
    </section>
  </div>
</Layout>
