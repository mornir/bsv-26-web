---
import Article from '../components/Article.astro'
import Layout from '../layouts/Layout.astro'
import { getArticles } from '../utils/sanity'

const articles = await getArticles()
---

<Layout title="BSV 2026">
  <div x-data="{ languages: ['de', 'fr']}">
    <div>
      <input type="checkbox" value="de" x-model="languages" name="german" />
      <label for="german">Deutsch</label>
    </div>
    <div>
      <input type="checkbox" value="fr" x-model="languages" name="french" />
      <label for="french">Französisch</label>
    </div>
    <div>
      <input type="checkbox" value="it" x-model="languages" name="italian" />
      <label for="italian">Italienisch</label>
    </div>

    <section class="mx-auto prose">
      <h1>TEST</h1>
      <p>
        Lorem ipsum dolor, sit amet consectetur adipisicing elit. Delectus
        ducimus itaque quis deleniti possimus iste saepe? Totam, neque dolorem!
        Esse hic dolorum natus recusandae quae rem quibusdam odio ea provident.
      </p>
    </section>
    <section class="mx-auto max-w-7xl">
      {articles.map((article) => <Article article={article} />)}
    </section>
  </div>
</Layout>
