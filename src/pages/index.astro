---
import Layout from '../layouts/Layout.astro'

const mainNav = [
  { text: 'Gesamtwerk', link: 'gesamtwerk' },
  { text: 'Inhaltsverzeichnis', link: 'inhaltsverzeichnis' },
  { text: 'Themen', link: 'themen' },
  { text: 'BSV Chatbot', link: 'bsv-chatbot' },
]
---

<Layout title="BSV 2026">
  <nav class="grid grid-cols-2 gap-8 max-w-3xl mx-auto">
    {
      mainNav.map((item) => (
        <a
          href={item.link}
          class="bg-slate-800 text-white p-8 text-center text-xl font-semibold"
        >
          {item.text}
        </a>
      ))
    }
  </nav>
</Layout>
