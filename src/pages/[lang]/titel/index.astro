---
import type { InferGetStaticParamsType } from 'astro'
import Layout from '@/layouts/Layout.astro'
import { getTitles } from '@/utils/sanity'

export async function getStaticPaths() {
  return [{ params: { lang: 'de' } }, { params: { lang: 'fr' } }]
}

type Params = InferGetStaticParamsType<typeof getStaticPaths>
const { lang } = Astro.params as Params

const titles = await getTitles()
---

<Layout title="Startseite">
  <div class="mt-32 grid place-content-center">
    <ul>
      {titles.map((title: any) => <li>{title.name[lang]}</li>)}
    </ul>
  </div>
</Layout>
