---
import Layout from '../layouts/Layout.astro'
---

<Layout title="Chatbot">
  <div
    class="max-w-lg mx-auto p-6 bg-white rounded-lg shadow-lg mt-10"
    x-data="chatbot"
  >
    <h1 class="text-2xl font-bold text-center mb-4">BSV Chatbot</h1>

    <div class="mb-4">
      <label for="query" class="block text-sm font-medium text-gray-700"
        >Ihre Frage zu den BSV 2026</label
      >
      <input
        type="text"
        id="query"
        x-model="query"
        class="mt-1 block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm"
        placeholder="Frage eintippen..."
      />
    </div>

    <button
      type="button"
      @click="submitQuery"
      :disabled="loading"
      class="w-full py-2 px-4 bg-violet-800 text-white rounded-md focus:outline-none focus:ring-2 focus:ring-blue-400 disabled:bg-gray-400"
    >
      <span x-show="!loading">BSV Chatbot fragen</span>
      <span x-show="loading">Einen Augenlick...</span>
    </button>

    <div class="mt-6" x-show="response">
      <h2 class="text-xl font-semibold">Antwort:</h2>
      <p class="text-gray-800 mt-2" x-text="response"></p>
    </div>
  </div>
</Layout>

<script>
  document.addEventListener('alpine:init', () => {
    window.Alpine.data('chatbot', () => ({
      query: '',
      response: '',
      loading: false,
      async submitQuery() {
        if (!this.query) return

        this.loading = true
        this.response = ''

        const res = await fetch('/.netlify/functions/chatbot', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ prompt: this.query }),
        })

        const data = await res.json()
        this.response = data.reply || data.error
        this.loading = false
      },
    }))
  })
</script>
