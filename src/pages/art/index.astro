---
import PageIndex from '@/layouts/PageIndex.astro'
import { getIndex } from '@/sanity/queries'
import { formatHeading } from '@/i18n/utils'
import { getLocale, getLocaleUrl } from 'astro-i18n-aut'

const locale = getLocale(Astro.url) as LangKeys

const { titles, chapters, sections, articles } = await getIndex()

/**
 * Build hierarchical tree
 */
function buildToc() {
  return titles.map((title) => {
    const titleChapters = chapters.filter((c) => c.titleNum === title.number)

    const titleSections = sections.filter(
      (s) => s.titleNum === title.number && !s.chapterNum
    )

    const titleArticles = articles.filter(
      (a) => a.titleNum === title.number && !a.chapterNum && !a.sectionNum
    )

    return {
      ...title,
      chapters: titleChapters.map((chapter) => {
        const chapterSections = sections.filter(
          (s) => s.titleNum === title.number && s.chapterNum === chapter.number
        )

        const chapterArticles = articles.filter(
          (a) =>
            a.titleNum === title.number &&
            a.chapterNum === chapter.number &&
            !a.sectionNum
        )

        return {
          ...chapter,
          sections: chapterSections.map((section) => {
            const sectionArticles = articles.filter(
              (a) =>
                a.titleNum === title.number &&
                a.chapterNum === chapter.number &&
                a.sectionNum === section.number
            )

            return {
              ...section,
              articles: sectionArticles,
            }
          }),
          articles: chapterArticles,
        }
      }),
      sections: titleSections.map((section) => {
        const sectionArticles = articles.filter(
          (a) =>
            a.titleNum === title.number &&
            !a.chapterNum &&
            a.sectionNum === section.number
        )

        return {
          ...section,
          articles: sectionArticles,
        }
      }),
      articles: titleArticles,
    }
  })
}

const toc = buildToc()

function artURL(slug: string) {
  return getLocaleUrl('/art/' + slug, locale)
}
---

<PageIndex title="Inhaltsverzeichnis">
  <nav class="space-y-8">
    {
      toc.map((title) => (
        <div class="rounded-lg border border-slate-300 bg-white p-6">
          <h2 class="mb-2 text-xl font-semibold text-slate-900 hover:underline">
            <a href={getLocaleUrl('/t/' + title.slug, locale)}>
              {formatHeading({ number: title.number, type: 'title' }, locale)}:
              {title.name[locale]}
            </a>
          </h2>

          <div class="mt-3 ml-2 space-y-6">
            {/* Articles directly under title */}
            {title.articles.length > 0 && (
              <ul class="space-y-1">
                {title.articles.map((article) => (
                  <li>
                    <a
                      href={artURL(article.slug)}
                      class="text-slate-700 transition-colors duration-150 hover:text-primary hover:underline"
                    >
                      Art. {article.number} {article.name[locale]}
                    </a>
                  </li>
                ))}
              </ul>
            )}

            {/* Sections directly under title */}
            {title.sections.map((section) => (
              <div class="pl-6">
                <h3 class="mb-1 font-medium text-slate-800">
                  {formatHeading(
                    { number: section.number, type: 'section' },
                    locale
                  )}
                  — {section.name[locale]}
                </h3>

                <ul class="mt-1 space-y-1 pl-2">
                  {section.articles.map((article) => (
                    <li>
                      <a
                        href={artURL(article.slug)}
                        class="text-slate-700 transition-colors duration-150 hover:text-primary hover:underline"
                      >
                        Art. {article.number} {article.name[locale]}
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            ))}

            {/* Chapters */}
            {title.chapters.map((chapter) => (
              <div class="space-y-3 pl-6">
                <h3 class="mb-1 font-medium text-slate-800">
                  {formatHeading(
                    { number: chapter.number, type: 'chapter' },
                    locale
                  )}
                  — {chapter.name[locale]}
                </h3>

                {/* Articles directly under chapter */}
                {chapter.articles.length > 0 && (
                  <ul class="space-y-1 pl-2">
                    {chapter.articles.map((article) => (
                      <li>
                        <a
                          href={artURL(article.slug)}
                          class="text-slate-700 transition-colors duration-150 hover:text-primary hover:underline"
                        >
                          Art. {article.number} {article.name[locale]}
                        </a>
                      </li>
                    ))}
                  </ul>
                )}

                {/* Sections inside chapter */}
                {chapter.sections.map((section) => (
                  <div class="pl-6">
                    <h4 class="mb-1 text-slate-700">
                      {formatHeading(
                        { number: section.number, type: 'section' },
                        locale
                      )}
                      — {section.name[locale]}
                    </h4>

                    <ul class="mt-1 space-y-1 pl-2">
                      {section.articles.map((article) => (
                        <li>
                          <a
                            href={artURL(article.slug)}
                            class="text-slate-700 transition-colors duration-150 hover:text-primary hover:underline"
                          >
                            Art. {article.number} {article.name[locale]}
                          </a>
                        </li>
                      ))}
                    </ul>
                  </div>
                ))}
              </div>
            ))}
          </div>
        </div>
      ))
    }
  </nav>
</PageIndex>
