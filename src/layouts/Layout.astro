---
import '../styles/global.css'

import SideNav from '../components/SideNav.astro'
interface Props {
  title: string
}

const { title } = Astro.props
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <div class="mb-24 mt-8">
      <header>
        <h1 class="text-2xl font-semibold m-4">DIGITALE BSV 2026</h1>
      </header>
      <div class="c-grid-wrapper">
        <div class="c-sidenav">
          <SideNav />
        </div>
        <main class="c-main">
          <slot />
        </main>
      </div>
      <!--    <footer>FOOTER</footer> -->
    </div>
  </body>
</html>

<style>
  .c-grid-wrapper {
    display: grid;
    grid-template-columns: 18rem 1fr;
    grid-template-areas: 'sidenav main';
  }

  .c-main {
    grid-area: 'main';
  }

  .c-sidenav {
    grid-area: 'sidenav';
  }
</style>
